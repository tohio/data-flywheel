# ─── Model APIs ───────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
HF_TOKEN=your_huggingface_token_here

# ─── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=data_flywheel

# ─── Elasticsearch ────────────────────────────────────────
ES_HOST=http://localhost:9200
ES_INDEX_LOGS=inference_logs
ES_INDEX_DATASETS=curated_datasets

# ─── Redis / Celery ───────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── MLflow ───────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=data-flywheel

# ─── Flywheel ─────────────────────────────────────────────
FLYWHEEL_CONFIG=configs/flywheel.yaml
MODELS_CONFIG=configs/models.yaml
EVAL_CRITERIA_CONFIG=configs/eval_criteria.yaml

# ─── App ──────────────────────────────────────────────────
LOG_LEVEL=INFO
ENV=development